{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "incremental": false,
    "rootDir": "./src",
    "outDir": "dist",
    "lib": [
      "es2020"
    ],
    "target": "es2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": [
      "jsdom"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/**"
  ]
}
